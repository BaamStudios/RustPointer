# Signal-Server – Konfiguration
#
# Wird per docker compose oder Shell-Env an den Container übergeben.
# Für rein lokalen Betrieb (`node server.js`) kann die Variable auch direkt
# vor dem Aufruf gesetzt werden, z.B.: `PORT=4000 node server.js`

# TCP-Port des WebSocket-Servers (Default 3000)
PORT=3000
