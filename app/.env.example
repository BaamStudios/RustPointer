# Presenter-Cursor App – Konfiguration
#
# Diese Datei kann neben der Presenter-Cursor.exe als ".env" abgelegt werden.
# Beispiel: kopiere diese Datei zu ".env" und passe die Werte an.

# WebSocket-URL des Signal-Servers (Pflichtfeld für die Verbindung).
# Beispiele:
#   ws://localhost:3000
#   ws://signal.example.com:3000
#   wss://signal.example.com           (TLS-Reverse-Proxy davor)
SIGNAL_SERVER_URL=ws://localhost:3000

# Optional: Standard-Room-ID, die im UI vorbefüllt wird.
# Beide Peers müssen dieselbe Room-ID benutzen.
ROOM_ID=test123

# Fenstertitel-Substring, nach dem das zu beobachtende Fenster gesucht wird.
# Match ist case-insensitive und darf auch nur ein Teilstring sein.
# Beispiele: "RustDesk", "Remote Desktop", "AnyDesk"
TARGET_WINDOW_TITLE=RustDesk

# Optional: Standard-Modus beim Start. Erlaubt: sender | receiver | both
DEFAULT_MODE=both

# Optional: TURN-Server für NAT-Traversal, falls STUN allein nicht reicht
# (z.B. bei symmetrischem NAT, Carrier-Grade-NAT, restriktiven Firewalls).
# Ohne TURN reicht oft schon STUN — falls die P2P-Verbindung dauerhaft auf
# "failed" geht, hier eine TURN-URL eintragen.
# Beispiel mit Coturn: turn:turn.example.com:3478
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=user
# TURN_CREDENTIAL=password
